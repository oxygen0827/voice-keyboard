# Voice Keyboard Agent 配置文件
# 复制为 config.yaml 并填入你的配置（config.yaml 不会被提交到 git）
#
# 快速开始（无需任何硬件）：
#   1. cp config.yaml.example config.yaml
#   2. 选择下方任意一个 stt provider，填写对应凭据
#   3. python -m agent.main --no-serial
#
# 也可以用 .env 文件代替 config.yaml（参考 .env.example），
# 适合部署、Docker、CI/CD 等不便管理 YAML 的场景。

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 方案一：智谱 AI GLM-4-Voice（推荐，一个 Key 搞定 STT + LLM）
# 参考：transmission_assistant 项目的智谱 AI 集成方式
# 控制台：https://open.bigmodel.cn/
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# stt:
#   provider: zhipuai
#   api_key: "..."                       # 智谱 AI API Key
#   model: glm-4-voice                   # 默认值，可省略
#   language: zh                         # zh（中文）/ en（英文）

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 方案二：阿里云 NLS（中文最优，支持方言）
# 控制台：https://nls-portal.console.aliyun.com/
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
stt:
  provider: aliyun
  access_key_id: "LTAI5t..."          # 阿里云 AccessKey ID
  access_key_secret: "..."             # 阿里云 AccessKey Secret
  app_key: "..."                       # NLS 项目的 Appkey
  region: cn-shanghai                  # cn-shanghai 或 cn-beijing
  language: zh                         # zh（中文）/ en（英文）

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 方案三：火山引擎 ASR（字节跳动，中文优化）
# 控制台：https://console.volcengine.com/speech/service/16
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# stt:
#   provider: volcengine
#   app_id: "..."                      # 应用 ID
#   token: "..."                       # 访问令牌（控制台生成）
#   cluster: volcengine_streaming_common
#   language: zh-CN

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 方案四：OpenAI Whisper（多语言，国际场景）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# stt:
#   provider: openai
#   api_key: "sk-..."                  # https://platform.openai.com/api-keys
#   model: whisper-1
#   language: zh

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 音频设置
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
audio:
  # 推荐：
  #   购买了 Voice Keyboard 硬件 → mode: vad（全程免手动，开口即唤醒）
  #   使用普通麦克风 / 内置麦克风 → mode: ptt（按住说话，避免背景噪音误触发）
  mode: ptt                 # ptt（按住说话）或 vad（常开，自动检测语音）
  ptt_key: right_alt        # 听写热键（按住说话）
  edit_key: right_ctrl      # 语音编辑热键（按住说修改指令，松开自动修改上一句）
  device: auto              # auto = 自动查找 ESP32 UAC 麦克风，找不到用系统默认
                            # 其他示例：
                            #   device: "MacBook"        # 内置麦克风
                            #   device: "Insta360"       # Insta360 麦克风
                            #   device: "DJI"            # 大疆麦克风
                            #   device: "Yeti"           # Blue Yeti USB 麦克风
                            #   device: 2                # 直接填序号（用 --list-devices 查）
  vad_aggressiveness: 2     # VAD 灵敏度 0~3（仅 mode: vad 时生效）

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LLM 文字编辑（语音修改上一句话）
# 与 stt 可以用同一个 provider，也可以分开配置
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
llm:
  provider: openai          # openai | aliyun（通义千问）| volcengine（豆包）| zhipuai（智谱 GLM）
  api_key: "sk-..."         # 与 stt 用同一个 key 即可（OpenAI 通用）
  model: gpt-4o-mini        # 推荐 gpt-4o-mini（快且便宜）

# 智谱 AI GLM 示例（与 stt.zhipuai 搭配，只需一个 API Key）：
# llm:
#   provider: zhipuai
#   api_key: "..."          # 智谱 AI API Key（同上方 stt 的 key）
#   model: glm-4-flash      # 推荐 glm-4-flash（快且便宜）

# 阿里云通义千问示例：
# llm:
#   provider: aliyun
#   api_key: "sk-..."       # DashScope API Key
#   model: qwen-turbo

# 火山引擎豆包示例：
# llm:
#   provider: volcengine
#   api_key: "..."          # ARK API Key
#   model: doubao-lite-4k
